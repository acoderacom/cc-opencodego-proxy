# claude-code-proxy-bun configuration
# Bun auto-loads this file from the project root. All values shown are defaults.

# --- Providers ---
# Configure at least one. Every model you route to below must belong to a
# configured provider.

# Opencode GO — serves both Anthropic /messages and OpenAI /chat/completions.
OPENCODE_API_KEY=""
OPENCODE_BASE_URL="https://opencode.ai/zen/go/v1"
# Comma-separated Opencode models that MUST use the OpenAI-compatible path.
# Any Opencode model not listed here uses the Anthropic passthrough.
OPENCODE_OPENAI_MODELS=""

# OpenRouter — always OpenAI-compatible.
OPENROUTER_API_KEY=""

# --- Routing ---
# Format: "<provider>/<model>"  —  provider is "opencode" or "open_router".
# Incoming Claude model ids are matched (case-insensitive substring) against
# "opus" / "sonnet" / "haiku" and routed to the matching override.
# Empty override → falls through to MODEL.
MODEL="opencode/minimax-m2.7"
MODEL_OPUS=""
MODEL_SONNET=""
MODEL_HAIKU=""

# --- Runtime ---
# Forward Claude "thinking" blocks to upstreams that support them.
ENABLE_THINKING=true

# Rolling-window limiter shared across all providers.
# Max PROVIDER_RATE_LIMIT requests per PROVIDER_RATE_WINDOW seconds.
PROVIDER_RATE_LIMIT=40
PROVIDER_RATE_WINDOW=60
# Max concurrent in-flight streams (semaphore).
PROVIDER_MAX_CONCURRENCY=5

# Upstream HTTP timeouts, in seconds.
HTTP_READ_TIMEOUT=120
HTTP_CONNECT_TIMEOUT=5

# --- Server ---
HOST="127.0.0.1"
PORT=8082
# Bun.serve idleTimeout (seconds, 0-255). Default 255 (Bun's max).
# Bun's own default of 10s closes SSE connections whenever a model pauses
# mid-generation; leave this at 255 unless you have a reason.
SERVER_IDLE_TIMEOUT=255
# Bearer token for incoming requests. Required when HOST is non-loopback —
# the server refuses to start with a public bind and an empty token.
# When set, Claude Code's ANTHROPIC_AUTH_TOKEN must match this value.
# Empty is allowed only when HOST is 127.0.0.1 / ::1 / localhost.
ANTHROPIC_AUTH_TOKEN=""

# --- Logging ---
# ""        → stdout/stderr (default)
# <path>    → append every log line to <path>
# "silent"  → disable logging entirely (equivalent to --quiet)
# Runtime overrides: --log-file PATH, --quiet
LOG_FILE=""
